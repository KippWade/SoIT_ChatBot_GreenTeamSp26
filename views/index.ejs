<html lang="en">
<%- include('./partials/head.ejs') %>

<body style="background-image: url(img/bg_faint.png);">
    <!-- Skip to main content link for keyboard users -->
    <a href="#main-content" class="visually-hidden-focusable" tabindex="0">Skip to main content</a>


    <%- include('./partials/nav.ejs') %>

    <main id="main-content" role="main">
        <div class="chat-container">
            <div class="chat-body" id="chat-body" aria-live="polite" role="status">
                <div class="message bot">
                    <div class="avatar"><img src="img/ivybot_face.png" alt="IvyBot avatar"></div>
                    <div class="content">
                        <p>Hi, I'm Ivy! I am here to assist you.</p>
                    </div>                       
                </div>
            </div>
        <!-- Language and user type selection unified below -->
        <div id="error-message" class="error" aria-live="assertive" role="alert" style="display:none;"></div>
        <div class="promptbox">
            <form id="chatForm" action="#" onsubmit="return false;">
                <!-- Hidden language input so server receives the chosen language with submissions -->
                <input type="hidden" id="language" name="language" value="">
                <div id="languageSection">
                    <div class="form-row">
                        <label for="languageDropdownBtn">Please select your preferred language to continue</label>
                        <div class="btn-group" style="margin-bottom:12px;">
                            <button id="languageDropdownBtn" type="button" class="btn btn-outline-secondary dropdown-toggle select-btn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Select language">Select</button>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item language-choice" data-lang="english" href="#">English</a></li>
                                <li><a class="dropdown-item language-choice" data-lang="filipino" href="#">Filipino</a></li>
                            </ul>
                        </div>
                        <%- include('partials/next_button.ejs', { id: 'languageNext', disabled: true, label: 'Next' }) %>
                    </div>
                </div>
                <div id="userTypeSection" style="display:none;">
                    <div class="form-row">
                        <label for="userType">Are you a guest, student, faculty, or staff?</label>
                        <div class="btn-group" style="margin-bottom:12px;">
                            <button id="userTypeDropdownBtn" type="button" class="btn btn-outline-secondary dropdown-toggle select-btn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Select user type">Select</button>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item usertype-choice" data-value="Guest" href="#">Guest</a></li>
                                <li><a class="dropdown-item usertype-choice" data-value="Student" href="#">Student</a></li>
                                <li><a class="dropdown-item usertype-choice" data-value="Faculty" href="#">Faculty</a></li>
                                <li><a class="dropdown-item usertype-choice" data-value="Staff" href="#">Staff</a></li>
                            </ul>
                        </div>
                        <!-- hidden input kept as single source of truth for legacy JS/server -->
                        <input type="hidden" id="userType" name="userType" value="">
                        <%- include('partials/back_button.ejs', { id: 'userTypeBack', label: 'Back' }) %>
                        <%- include('partials/next_button.ejs', { id: 'userTypeNext', disabled: true, label: 'Next' }) %>
                    </div>
                </div>
                <div id="emailSection" style="display:none;">
                    <!-- Ensure valid Ivy Tech email and will only accepts Ivy Tech email if the "Guest" is not chosen-->
                    <label for="schoolEmail" class="visually-hidden">School Email</label>
                    <input type="email" id="schoolEmail" name="schoolEmail" placeholder="Enter your school email" pattern=".+@ivytech\.edu" aria-describedby="schoolEmailHelp"> 
                    <span id="schoolEmailHelp" class="visually-hidden">Enter your Ivy Tech email address. Required unless you are a guest.</span>
                    <%- include('partials/back_button.ejs', { id: 'emailBack', label: 'Back' }) %>
                    <button type="button" id="emailNext" disabled>Next</button>
                </div>
                <div id="questionSection" style="display:none;">
                    <label for="prompt" class="visually-hidden">Type your question</label>
                    <input type="text" id="prompt" name="prompt" placeholder="Type a question..." required autofocus aria-label="Type your question">
                    <button type="submit" style="display:none"></button>
                </div>
            </form>
        </div>
    </main>
      <!-- Language confirmation modal (asks user if they want to continue with selected language) -->
        <div class="modal fade" id="languageConfirmModal" tabindex="-1" aria-labelledby="languageConfirmModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="languageConfirmModalLabel">Chosen Language</h5>
                    </div>
                    <div class="modal-body">
                       Are you sure you want to continue in <span id="languageConfirmName"></span>?
                    </div>
                    <div class="modal-footer">
                        <button type="button" id="languageChangeBtn" class="btn" style="background-color:#ffffff;color:#073c1f;border:1px solid rgba(11,79,43,0.14);" data-bs-dismiss="modal">Change Language</button>
                        <button type="button" id="languageContinueBtn" class="btn btn-primary" data-bs-dismiss="modal">Continue</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bootstrap's JS Script (load before our chatbot script so bootstrap APIs are available) -->
     <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
     <!-- ChatBot Fetch Script -->
     <script src="/scripts/chatbot.js"></script>


    <%- include('./partials/footer.ejs') %>

</body>
</html>